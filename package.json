{
  "name": "epicentra",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"next dev\" \"ts-node --compiler-options '{\\\"module\\\":\\\"CommonJS\\\",\\\"target\\\":\\\"ES2015\\\"}' server/index.ts\"",
    "dev:web": "next dev",
    "dev:socket": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' server/index.ts",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:migrate": "prisma migrate dev",
    "db:seed": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed.ts",
    "db:reset": "prisma migrate reset --force && npm run db:seed"
  },
  "prisma": {
    "seed": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed.ts"
  },
  "dependencies": {
    "@ai-sdk/groq": "^3.0.34",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/pg": "^8.20.0",
    "@types/three": "^0.169.0",
    "ai": "^6.0.149",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "lucide-react": "^1.7.0",
    "nanoid": "^5.1.7",
    "next": "^15.5.15",
    "next-auth": "^4.24.13",
    "pg": "^8.20.0",
    "prisma": "^6.19.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hot-toast": "^2.6.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "three": "^0.169.0",
    "use-debounce": "^10.1.1"
  },
  "overrides": {
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.19.39",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^8",
    "eslint-config-next": "^15.5.15",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
