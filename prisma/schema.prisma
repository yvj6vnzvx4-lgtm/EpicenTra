generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth & Users ────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(MANAGER)
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  eventsOwned Event[]      @relation("EventOwner")
  assignments EventMember[]
  notes       Note[]
  agentTasks  AgentTask[]  @relation("TaskCreator")
}

enum Role {
  ADMIN
  DIRECTOR
  MANAGER
  COORDINATOR
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users  User[]
  events Event[]
}

// ─── Events ──────────────────────────────────────────────

model Event {
  id          String      @id @default(cuid())
  title       String
  status      EventStatus @default(DRAFT)
  description String?

  startDate    DateTime?
  endDate      DateTime?
  timezone     String?   @default("America/New_York")
  venueName    String?
  venueAddress String?
  venueCity    String?
  venueState   String?
  venueZip     String?
  venueNotes   String?

  objectives         String?
  targetAudience     String?
  brandGuidelines    String?
  expectedAttendance Int?

  totalBudget Decimal? @db.Decimal(12, 2)
  budgetNotes String?

  layoutData Json?

  planLockedAt DateTime?
  completedAt  DateTime?
  deletedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerId        String
  owner          User         @relation("EventOwner", fields: [ownerId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  members     EventMember[]
  budgetItems BudgetItem[]
  notes       Note[]
  agentTasks  AgentTask[]
  checklist   ChecklistItem[]
  vendors     EventVendor[]
  staffSlots  StaffSlot[]
}

enum EventStatus {
  DRAFT
  PLANNING
  PLAN_LOCKED
  IN_EXECUTION
  LIVE
  COMPLETED
  CANCELLED
}

model EventMember {
  id   String @id @default(cuid())
  role String

  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId  String
  user    User   @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
}

// ─── Budget ──────────────────────────────────────────────

model BudgetItem {
  id          String   @id @default(cuid())
  category    String
  description String
  estimated   Decimal  @db.Decimal(12, 2)
  actual      Decimal? @db.Decimal(12, 2)
  status      String   @default("pending")
  notes       String?

  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Collaborative Notes ─────────────────────────────────

model Note {
  id       String   @id @default(cuid())
  content  String
  type     NoteType @default(USER)
  isPinned Boolean  @default(false)
  metadata Json?

  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId  String?
  user    User?  @relation(fields: [userId], references: [id])

  parentId String?
  parent   Note?   @relation("NoteThread", fields: [parentId], references: [id])
  replies  Note[]  @relation("NoteThread")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum NoteType {
  USER
  AGENT
  SYSTEM
  DECISION
}

// ─── Agent Tasks ─────────────────────────────────────────

model AgentTask {
  id         String          @id @default(cuid())
  prompt     String
  status     AgentTaskStatus @default(PENDING)
  result     String?
  resultMeta Json?

  eventId     String
  event       Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User   @relation("TaskCreator", fields: [createdById], references: [id])

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?
}

enum AgentTaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELLED
}

// ─── Checklist ───────────────────────────────────────────

model ChecklistItem {
  id          String    @id @default(cuid())
  title       String
  description String?
  isCompleted Boolean   @default(false)
  dueDate     DateTime?
  category    String?
  sortOrder   Int       @default(0)
  source      String    @default("manual")

  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Vendors ─────────────────────────────────────────────

model EventVendor {
  id           String   @id @default(cuid())
  vendorName   String
  category     String
  contactName  String?
  contactEmail String?
  contactPhone String?
  status       String   @default("prospective")
  cost         Decimal? @db.Decimal(12, 2)
  notes        String?

  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Staff Slots ─────────────────────────────────────────

model StaffSlot {
  id         String    @id @default(cuid())
  roleName   String
  quantity   Int       @default(1)
  startTime  DateTime?
  endTime    DateTime?
  hourlyRate Decimal?  @db.Decimal(8, 2)
  notes      String?
  isFilled   Boolean   @default(false)

  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
